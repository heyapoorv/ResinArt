# ─────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Log level: error | warn | info | http | debug
LOG_LEVEL=debug

# ─────────────────────────────────────────────
# MONGODB ATLAS
# ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/aura_resin?retryWrites=true&w=majority

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
# Must be at least 32 characters in production
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_32chars_min
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# CLOUDINARY
# ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=aura_resin

# ─────────────────────────────────────────────
# CORS – comma-separated list of allowed origins
# ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─────────────────────────────────────────────
# SEED CREDENTIALS (used by: node utils/seed.js)
# Change immediately after first login in production!
# ─────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@auraresin.art
SEED_ADMIN_PASSWORD=AuraResin@2024!
